# This file is automatically generated by Chef
# Any changes will be overwritten

[DEFAULT]
auth_encryption_key = <%= @auth_encryption_key %>
heat_metadata_server_url = http://<%= @endpoint %>:8000
heat_waitcondition_server_url = http://<%= @endpoint %>:8000/v1/waitcondition
region_name_for_services = <%= @region %>
stack_domain_admin = heat_domain_admin
stack_domain_admin_password = <%= @heat_domain_admin %>
stack_user_domain_name = heat
transport_url = <%= @transport_url %>
<% if @listen_ip && @listen_ip != '*' -%>

[heat_api]
bind_host = <%= @listen_ip %>

[heat_api_cfn]
bind_host = <%= @listen_ip %>
<% end -%>

[cache]
memcache_servers = <%= @memcached_endpoint %>
enabled = true
backend = dogpile.cache.memcached

[clients_keystone]
auth_url = https://<%= @auth_endpoint %>:5000

[database]
connection = <%= @database_connection %>

[keystone_authtoken]
auth_type = v3password
auth_url = https://<%= @auth_endpoint %>:5000/v3
memcached_servers = <%= @memcached_endpoint %>
password = <%= @service_pass %>
project_domain_name = Default
project_name = service
service_token_roles = admin
service_token_roles_required = True
user_domain_name = Default
username = heat
www_authenticate_uri = https://<%= @auth_endpoint %>:5000/v3

<% if @rabbit_quorum_queue || @rabbit_tls -%>
[oslo_messaging_rabbit]
<% if @rabbit_quorum_queue -%>
rabbit_quorum_queue = true
<% end -%>
<% if @rabbit_tls -%>
ssl = true
<% if @rabbit_ssl_ca_file -%>
ssl_ca_file = <%= @rabbit_ssl_ca_file %>
<% end -%>
<% end -%>

<% end -%>
[oslo_messaging_notifications]
driver = messagingv2

[trustee]
auth_type = v3password
auth_url = https://<%= @auth_endpoint %>:5000/v3
password = <%= @service_pass %>
user_domain_name = Default
username = heat
